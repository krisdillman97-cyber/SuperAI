# SuperAI — Local Configuration Template
# Copy this file to local.properties and fill in your values
# DO NOT commit local.properties to version control

# Android SDK Path (required on Linux/macOS)
# On Windows, this is usually auto-detected
# sdk.dir=/path/to/Android/sdk

# Your app's local configuration
# Add any local build properties here

# Example: API Keys (if needed locally)
# Note: Never commit real API keys
# api_key=YOUR_KEY_HERE

# Keystore configuration for signing
# storeFile=path/to/keystore
# storePassword=your_password
# keyAlias=your_key_alias
# keyPassword=your_key_password
