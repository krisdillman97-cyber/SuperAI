<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme — Compose handles all real theming; this is the XML fallback -->
    <style name="Theme.SuperAI" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/superai_dark_bg</item>
        <item name="android:statusBarColor">@color/superai_dark_bg</item>
        <item name="android:navigationBarColor">@color/superai_dark_bg</item>
    </style>

    <!-- Splash screen theme (core-splashscreen) -->
    <style name="Theme.SuperAI.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/superai_dark_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.SuperAI</item>
    </style>
</resources>
